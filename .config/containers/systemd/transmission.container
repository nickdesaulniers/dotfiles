[Unit]
Description=Transmission (LinuxServer)
After=network-online.target
Wants=network-online.target

[Container]
Image=lscr.io/linuxserver/transmission:latest
ContainerName=transmission
Environment=TZ=America/Los_Angeles
Volume=/home/nick/transmission/config:/config
Volume=/backups/nick/downloads:/downloads:Z

# Permissions errors without these.
UserNS=keep-id:uid=1000,gid=1000
Environment=PUID=1000
Environment=PGID=1000

# WebUI not routed through traefik.
PublishPort=9091:9091
PublishPort=51413:51413
PublishPort=51413:51413/udp

[Service]
Restart=always
TimeoutStartSec=90

[Install]
WantedBy=default.target
