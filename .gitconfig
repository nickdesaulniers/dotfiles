[color "diff"]
  ; highlight more info in git diff
  meta = yellow bold
  frag = magenta bold
  ; make trailing whitespace apparent in diffs
  whitespace = red reverse
[user]
  name = Nick Desaulniers
  email = nick.desaulniers@gmail.com
  ;email = ndesaulniers@google.com
[core]
  ; is unique per host...
  ;excludesfile = /Users/Nicholas/.gitignore_global
  ; open vim for commits
  editor = vim
[push]
  default = current
[am]
  threeWay = true
  ; fall back to three way merge when git am fails
[sendemail]
  ; setup for using git send-email; prompts for password
  smtpuser = nick.desaulniers@gmail.com
  smtpserver = smtp.googlemail.com
  smtpencryption = tls
  smtpserverport = 587
  ; go/sendgmr
  ;smtpserver = /usr/bin/sendgmr
  ;smtpuser = ndesaulniers@google.com
  ;b4-really-reflect-via = /usr/bin/sendgmr
[branch]
  ; show ahead/behind for local branches from which they were branched from
  autosetupmerge = always
;[patatt]
;  signingkey = ed25519:20260528
;  selector = 20260528
;[b4]
;  send-endpoint-web = https://lkml.kernel.org/_b4_submit
